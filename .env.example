# Discord OAuth App (discord.com/developers/applications)
DISCORD_CLIENT_ID=deine_discord_client_id
DISCORD_CLIENT_SECRET=dein_discord_client_secret

# Discord Bot (selbe App -> Bot-Tab)
DISCORD_BOT_TOKEN=dein_bot_token
DISCORD_GUILD_ID=deine_server_id
DISCORD_MEMBER_ROLE_ID=rollen_id_die_vergeben_wird
DISCORD_LOG_CHANNEL_ID=kanal_id_von_maxrankbot

# NextAuth
NEXTAUTH_URL=https://deine-domain.vercel.app
NEXTAUTH_SECRET=generiere_mit_openssl_rand_base64_32
